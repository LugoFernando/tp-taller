generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

model producto {
  id            Int     @id @default(autoincrement())
  nombre        String  @db.VarChar(100)
  descripcion   String  @db.VarChar(500)
  clasificacion String  @db.VarChar(50)
  precio        Float
  activo        Boolean @default(true)
  imagen        String? @db.VarChar(500)
}

model usuario {
  id        Int    @id @default(autoincrement())
  email     String @unique
  password  String
  nombre    String
  apellido  String
  direccion String
  rol       String @default("cliente")
}
